generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public"]
}

// ─────────────────────────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String   // Hashed with bcrypt
  role      String   // 'ADMIN' | 'SALESPERSON' | 'AGENT'
  agentId   String?  @unique @map("agent_id")
  agent     Agent?   @relation(fields: [agentId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────
// AGENT HIERARCHY
// ─────────────────────────────────────────────────────────────────

model Agent {
  id              String    @id @default(uuid())
  agentCode       String    @unique @map("agent_code")
  name            String
  phone           String?   
  email           String?   
  type            String    // 'CHANNEL_PARTNER' | 'SALESPERSON' | 'SUB_AGENT'

  parentId        String?   @map("parent_id")
  parent          Agent?    @relation("AgentHierarchy", fields: [parentId], references: [id])
  children        Agent[]   @relation("AgentHierarchy")

  commissionType  String    @default("PERCENTAGE") @map("commission_type")
  commissionRate  Float     @default(5.0) @map("commission_rate")
  isActive        Boolean   @default(true) @map("is_active")
  
  tiers           CommissionTier[] 

  user            User?
  ownedLeads      Lead[]    @relation("LeadOwner")
  assignments     LeadAssignment[]
  commissions     Commission[]
  payouts         Payout[]  

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("agents")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────
// LEADS
// ─────────────────────────────────────────────────────────────────

model Lead {
  id              String    @id @default(uuid())
  name            String
  email           String?   
  location        String    
  notes           String?   

  sourceType      String    @map("source_type")
  ownerId         String    @map("owner_id")
  owner           Agent     @relation("LeadOwner", fields: [ownerId], references: [id])

  status          String    @default("NEW")

  contacts        LeadContact[]
  assignments     LeadAssignment[]
  deals           Deal[]
  activities      LeadActivity[] 

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("leads")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────
// LEAD CONTACTS
// ─────────────────────────────────────────────────────────────────

model LeadContact {
  id          String   @id @default(uuid())
  leadId      String   @map("lead_id")
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  phoneNumber String   @unique @map("phone_number")
  isPrimary   Boolean  @default(false) @map("is_primary")
  label       String?  
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([phoneNumber])
  @@map("lead_contacts")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────
// LEAD ASSIGNMENTS
// ─────────────────────────────────────────────────────────────────

model LeadAssignment {
  id          String   @id @default(uuid())
  leadId      String   @map("lead_id")
  lead        Lead     @relation(fields: [leadId], references: [id])
  agentId     String   @map("agent_id")
  agent       Agent    @relation(fields: [agentId], references: [id])
  assignedBy  String   @map("assigned_by")
  isActive    Boolean  @default(true) @map("is_active")
  assignedAt  DateTime @default(now()) @map("assigned_at")

  @@map("lead_assignments")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────
// DEALS
// ─────────────────────────────────────────────────────────────────

model Deal {
  id              String    @id @default(uuid())
  leadId          String    @map("lead_id")
  lead            Lead      @relation(fields: [leadId], references: [id])
  dealValue       Float     @map("deal_value")
  category        String?   
  status          String    @default("OPEN") 
  paymentReceived Boolean   @default(false) @map("payment_received")
  paymentDate     DateTime? @map("payment_date")
  closedAt        DateTime? @map("closed_at")
  notes           String?   

  commissions     Commission[]

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([leadId]) 
  @@map("deals")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────
// COMMISSIONS
// ─────────────────────────────────────────────────────────────────

model Commission {
  id          String   @id @default(uuid())
  dealId      String   @map("deal_id")
  deal        Deal     @relation(fields: [dealId], references: [id])
  agentId     String   @map("agent_id")
  agent       Agent    @relation(fields: [agentId], references: [id])

  role           String   // 'OWNER' | 'CLOSER' | 'OVERRIDE'
  commissionType String   @default("PERCENTAGE") @map("commission_type")
  rate           Float    
  amount         Float    

  status      String   @default("PENDING") 
  disputeNote String?  @map("dispute_note")

  payout      Payout?  

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([dealId, agentId, role]) 
  @@index([agentId])               
  @@index([status])                
  @@map("commissions")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────
// PAYOUTS 
// ─────────────────────────────────────────────────────────────────

model Payout {
  id           String     @id @default(uuid())
  commissionId String     @unique @map("commission_id")
  commission   Commission @relation(fields: [commissionId], references: [id])
  agentId      String     @map("agent_id")
  agent        Agent      @relation(fields: [agentId], references: [id])
  amount       Float
  method       String?    
  reference    String?    
  paidAt       DateTime   @default(now()) @map("paid_at")
  paidBy       String     @map("paid_by")

  @@map("payouts")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────
// LEAD ACTIVITY LOG
// ─────────────────────────────────────────────────────────────────

model LeadActivity {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  lead      Lead     @relation(fields: [leadId], references: [id])
  type      String   
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  note      String?
  byUserId  String   @map("by_user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("lead_activities")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────
// COMMISSION TIERS (Volume based)
// ─────────────────────────────────────────────────────────────────

model CommissionTier {
  id              String   @id @default(cuid())
  agentId         String   @map("agent_id")
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  volumeThreshold Float    @map("volume_threshold")
  rate            Float    
  
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("commission_tiers")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────
// SOLAR QUOTATION MODELS
// ─────────────────────────────────────────────────────────────────

model SystemType {
  id           String    @id @default(uuid())
  name         String    @unique
  description  String?
  defaultTerms String[]  @default([]) @map("default_terms")
  
  products     Product[]
  components   Component[]
  quotations   Quotation[]
  
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("system_types")
  @@schema("public")
}

model Product {
  id           String     @id @default(uuid())
  systemTypeId String     @map("system_type_id")
  systemType   SystemType @relation(fields: [systemTypeId], references: [id])
  
  name         String
  brand        String?
  capacityKw   Float?     @map("capacity_kw")
  phase        Int        @default(1)
  basePrice    Float      @map("base_price")
  gstRate      Float      @default(8.9) @map("gst_rate")
  isActive     Boolean    @default(true) @map("is_active")
  
  createdAt    DateTime   @default(now()) @map("created_at")

  @@map("products")
  @@schema("public")
}

model IntegratedProduct {
  id                  String   @id @default(uuid())
  brand               String
  systemKw            Float    @map("system_kw")
  phase               String
  price               Float
  inverterCapacityKw  Float    @map("inverter_capacity_kw")
  moduleWatt          Int      @map("module_watt")
  moduleType          String?  @map("module_type")
  noOfModules         Int      @map("no_of_modules")
  acdbNos             Int      @default(1) @map("acdb_nos")
  dcdbNos             Int      @default(1) @map("dcdb_nos")
  earthingRodNos      Int      @default(3) @map("earthing_rod_nos")
  earthingChemicalNos Int      @default(3) @map("earthing_chemical_nos")
  acWireBrand         String?  @map("ac_wire_brand")
  acWireLengthMtr     Int      @default(10) @map("ac_wire_length_mtr")
  dcWireBrand         String?  @map("dc_wire_brand")
  dcWireLengthMtr     Int      @default(20) @map("dc_wire_length_mtr")
  earthingWireBrand   String?  @map("earthing_wire_brand")
  earthingWireLengthMtr Int    @default(90) @map("earthing_wire_length_mtr")
  lightingArrestorQty Int      @default(1) @map("lighting_arrestor_qty")
  
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("integrated_products")
  @@schema("public")
}

model Component {
  id             String     @id @default(uuid())
  systemTypeId   String?    @map("system_type_id")
  systemType     SystemType? @relation(fields: [systemTypeId], references: [id])
  
  name           String
  description    String?
  defaultQuantity String     @map("default_quantity")
  defaultMake    String     @map("default_make")
  sortOrder      Int        @default(0) @map("sort_order")
  isDefault      Boolean    @default(true) @map("is_default")
  
  createdAt      DateTime   @default(now()) @map("created_at")

  @@map("solar_product_components")
  @@schema("public")
}

model Quotation {
  id              String      @id @default(uuid())
  quoteNumber     String?     @map("quote_number")
  customerName    String      @map("customer_name")
  customerPhone   String?     @map("customer_phone")
  customerAddress String?     @map("customer_address")
  customerEmail   String?     @map("customer_email")
  quoteDate       DateTime    @default(now()) @map("quote_date")
  
  systemTypeId    String?     @map("system_type_id")
  systemType      SystemType? @relation(fields: [systemTypeId], references: [id])
  
  capacityKw      Float?      @map("capacity_kw")
  phase           Int         @default(1)
  brand           String?
  basePrice       Float?      @map("base_price")
  gstRate         Float       @default(8.9) @map("gst_rate")
  gstAmount       Float?      @map("gst_amount")
  totalAmount     Float?      @map("total_amount")
  centralSubsidy  Float       @default(0) @map("central_subsidy")
  stateSubsidy    Float       @default(0) @map("state_subsidy")
  
  terms           Json?       // Array of strings
  components      Json?       // Array of QuotationComponent objects
  savingsData     Json?       @map("savings_data")
  
  salesperson     String?
  status          String      @default("draft")
  pdfUrl          String?     @map("pdf_url")
  
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@map("quotations")
  @@schema("public")
}
